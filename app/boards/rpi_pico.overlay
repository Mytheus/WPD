/*
 * Overlay de devicetree para Raspberry Pi Pico (RP2040) — Wearable de Correção de Postura.
 *
 * Objetivo: reservar, no nível de hardware, os periféricos previstos em
 * docs/ARCHITECTURE.md (Seção 7 "Identificação dos Periféricos") que ainda não têm
 * driver/consumidor concreto:
 *   - i2c0: barramento do futuro IMU (sensor ainda não escolhido — ver ADR 0002).
 *   - botão de ack/modo (gpio-keys).
 *   - canal PWM do motor de vibração.
 *
 * Responsabilidade: única fonte de verdade sobre pinagem física desta placa.
 * Dependências: dt-bindings de GPIO, I2C e pinctrl do RP2040 (fornecidos pelo módulo
 * hal_rpi_pico, importado via west.yml).
 * Quem utiliza: drivers/sensor/* (Etapa 4), app/src/modules/button (Etapa 4),
 *               app/src/modules/notification (Etapa 7 redefinida — ver ADR 0001).
 *
 * PLACEHOLDERS DE PINAGEM (combinados com o usuário na Etapa 1, ajustáveis em 1 linha
 * quando a fiação física definitiva for confirmada — nenhum módulo de software depende
 * do número do pino, apenas do alias/label):
 *   - I2C0 SDA/SCL -> GP4 / GP5
 *   - Botão de ack/modo -> GP14
 *   - PWM do motor de vibração -> GP15 (slice 7, canal B)
 *
 * Macros de pinmux confirmadas contra
 * zephyr/include/zephyr/dt-bindings/pinctrl/rpi-pico-pinctrl-common.h (workspace real):
 * I2C0_SDA_P4, I2C0_SCL_P5, PWM_7B_P15 (não "PWM_B7_P15" — nome corrigido após o
 * primeiro `west build`, que falhou com "expected number or parenthesized expression"
 * na linha do pinmux do PWM).
 *
 * Etapa 2 (infraestrutura): o binding "gpio-keys" é consumido pelo subsistema de Input
 * do Zephyr (drivers/input/input_gpio_keys.c, CONFIG_INPUT + CONFIG_INPUT_GPIO_KEYS), não
 * por leitura direta de GPIO. Esse driver exige a propriedade `zephyr,code` em cada botão
 * (DT_PROP sem fallback) — ausente na Etapa 1 porque CONFIG_INPUT estava desligado e o
 * driver nunca era compilado contra este overlay. Adicionada agora que CONFIG_INPUT=y.
 * O código semântico real (ack/reset/modo) só é interpretado em software na Etapa 4
 * (button_module) — aqui é só o requisito mínimo do binding de hardware.
 */

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2040-pinctrl.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	buttons: buttons {
		compatible = "gpio-keys";

		ack_button: button_0 {
			gpios = <&gpio0 14 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Ack/Mode button (placeholder: GP14)";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	aliases {
		ack-button = &ack_button;
	};
};

&pinctrl {
	/* Estados de pinctrl próprios da aplicação — isolados dos defaults do board file
	 * para não colidir com nomes que o board já possa definir.
	 */
	i2c0_wpd_default: i2c0_wpd_default {
		group1 {
			pinmux = <I2C0_SDA_P4>, <I2C0_SCL_P5>;
			input-enable;
			input-schmitt-enable;
		};
	};

	pwm7_wpd_default: pwm7_wpd_default {
		group1 {
			pinmux = <PWM_7B_P15>;
		};
	};
};

&i2c0 {
	status = "okay";
	pinctrl-0 = <&i2c0_wpd_default>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	/* Nenhum nó de sensor concreto ainda: o modelo do IMU não foi escolhido (ADR 0002).
	 * Adicionado quando o driver out-of-tree for implementado (Etapa 4).
	 */
};

/* RP2040 tem um único controlador PWM (`pwm`, label do SoC) multiplexando 8 slices x 2
 * canais (A/B) — não há node "pwm7" por slice. O canal é selecionado em tempo de uso via
 * pwm-cells: <&pwm CHANNEL PERIOD FLAGS>, com CHANNEL = slice*2 + (0=A, 1=B).
 * GP15 = slice 7 canal B (PWM_7B_P15) -> CHANNEL = 7*2+1 = 15.
 */
&pwm {
	status = "okay";
	pinctrl-0 = <&pwm7_wpd_default>;
	pinctrl-names = "default";
	/* Nenhum binding de atuador ainda: o motor de vibração será consumido diretamente
	 * pela Sensor/PWM API dentro do notification_module (Etapa 7 redefinida, ADR 0001),
	 * não por um node de devicetree genérico tipo "pwm-leds".
	 */
};

/* Etapa 2 (infraestrutura): partição de flash dedicada ao backend NVS do subsistema
 * Settings (RF07/RNF05). O board rpi_pico não define uma "storage_partition" própria —
 * o flash inteiro após o bootloader é um único `code_partition` read-only. Reservamos os
 * últimos 32 KiB (8 setores de 4 KiB, o erase-block-size do driver flash_rpi_pico) para
 * NVS, encolhendo `code_partition` na mesma medida. A aplicação atual (~26 KiB) fica
 * folgada dentro do novo tamanho de `code_partition` (~2 MiB - 32 KiB).
 */
&code_partition {
	reg = <0x100 (DT_SIZE_M(2) - 0x100 - DT_SIZE_K(32))>;
};

&flash0 {
	partitions {
		storage_partition: partition@1f8000 {
			compatible = "zephyr,mapped-partition";
			label = "storage-partition";
			reg = <0x1f8000 DT_SIZE_K(32)>;
		};
	};
};
